# ─── Base44 (optional sync) ───────────────────────────────────────────────────
# "true" = use Base44 SDK for entities/functions. Anything else = local-first (no Base44 HTTP).
VITE_ENABLE_BASE44=false

# App ID — found in Base44 Dashboard URL: base44.com/apps/<APP_ID>/
VITE_BASE44_APP_ID=your_base44_app_id

# App base URL — your published Base44 app domain
VITE_BASE44_APP_BASE_URL=https://your-app-name.base44.app

# Optional: exact Obsidian desktop vault name as registered inside the local app.
# Use this if the generated vault name differs from the real one in obsidian:// links.
VITE_OBSIDIAN_VAULT_NAME=your_obsidian_vault_name

# Optional: local filesystem path of the same Obsidian vault (client + Vite dev server fallback).
VITE_OBSIDIAN_VAULT_PATH=C:\\path\\to\\your\\obsidian\\vault

# Optional: server-side vault path for /api/vault/* (preferred in .env.local if set).
# Falls back to VITE_OBSIDIAN_VAULT_PATH when unset.
OBSIDIAN_VAULT_PATH=C:\\path\\to\\your\\obsidian\\vault

# Access token — for Node.js seed scripts only (not needed for the app itself)
# Get from browser: DevTools → Application → Local Storage → base44_access_token
# Store in .env.local (never commit)
BASE44_TOKEN=your_base44_token

# ─── AI ───────────────────────────────────────────────────────────────────────
# Google AI Studio API key — required for AI video analysis (AnalyzeVideo function)
# Get a free key at: https://aistudio.google.com/app/apikey
# Deploy to Base44 Functions → AnalyzeVideo → Environment Variables
GEMINI_API_KEY=paste_your_gemini_api_key_here

# Set to "true" to skip real Gemini calls and return mock Hebrew data (UI testing)
GEMINI_MOCK=false

# Gemini Gem shortcut — political transcript paste flow (Transcript modal → Gemini פוליטי)
VITE_GEMINI_POLITICAL_GEM_URL=https://gemini.google.com/gem/99b982aa44b6

# Gemini Gem shortcut — fundamental transcript paste flow (Transcript modal → Gemini פונדמנטלי)
VITE_GEMINI_FUNDAMENTAL_GEM_URL=https://gemini.google.com/gem/593021ea2734

# Claude / Anthropic API key for the Claude video analyzer proxy.
# Keep the real value only in .env.local or Base44 Environment Variables.
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── YouTube Data API v3 (optional) ───────────────────────────────────────────
# Full video descriptions (for real chapter timestamps). Put the real value in .env.local only.
# Restrict the key in Google Cloud → APIs & Services → Credentials → HTTP referrers.
VITE_YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# ─── Google Drive (optional — moves heavy AI analysis out of localStorage) ─────
# Create OAuth 2.0 credentials in Google Cloud Console → APIs & Services → Credentials
# → Create credentials → OAuth client ID → Web application
# → Add authorized redirect URI: http://localhost:5174/api/gdrive/callback
# No VITE_ prefix — these are server-side only, never exposed to the browser.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Name of the folder created in Google Drive (default shown below)
GOOGLE_DRIVE_FOLDER_NAME=yt-mentor-analysis
