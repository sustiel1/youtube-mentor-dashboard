# ─── Base44 ───────────────────────────────────────────────────────────────────
# App ID — found in Base44 Dashboard URL: base44.com/apps/<APP_ID>/
VITE_BASE44_APP_ID=your_base44_app_id

# App base URL — your published Base44 app domain
VITE_BASE44_APP_BASE_URL=https://your-app-name.base44.app

# Access token — for Node.js seed scripts only (not needed for the app itself)
# Get from browser: DevTools → Application → Local Storage → base44_access_token
# Store in .env.local (never commit)
BASE44_TOKEN=your_base44_token

# ─── AI ───────────────────────────────────────────────────────────────────────
# Google AI Studio API key — required for AI video analysis (AnalyzeVideo function)
# Get a free key at: https://aistudio.google.com/app/apikey
# Deploy to Base44 Functions → AnalyzeVideo → Environment Variables
GEMINI_API_KEY=your_gemini_api_key

# Set to "true" to skip real Gemini calls and return mock Hebrew data (UI testing)
GEMINI_MOCK=false
