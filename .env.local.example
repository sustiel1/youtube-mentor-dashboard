# .env.local — קובץ זה לא נכנס ל-git (.gitignore כבר מכיל .env.local)
#
# Local-first (ברירת מחדל): ללא קריאות ל-Base44 מהדפדפן
# VITE_ENABLE_BASE44=false
#
# BASE44_TOKEN: access token לסקריפטי Node (seed וכו')
# קבל אותו מהדפדפן כשהאפליקציה פתוחה:
#   DevTools → Console → localStorage.getItem('base44_access_token')
#
BASE44_TOKEN=your_token_here

# YouTube Data API v3 — פרקים עם timestamps אמיתיים מתוך תיאור מלא
# VITE_YOUTUBE_API_KEY=YOUR_KEY

# Gemini
# GEMINI_API_KEY=paste_your_gemini_api_key_here

# Political Gem URL for transcript modal shortcut (optional override)
# VITE_GEMINI_POLITICAL_GEM_URL=https://gemini.google.com/gem/99b982aa44b6

# Fundamental Gem URL for transcript modal shortcut (optional override)
# VITE_GEMINI_FUNDAMENTAL_GEM_URL=https://gemini.google.com/gem/593021ea2734

# Claude / Anthropic
# VITE_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
