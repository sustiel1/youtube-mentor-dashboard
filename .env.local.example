# .env.local — קובץ זה לא נכנס ל-git (.gitignore כבר מכיל .env.local)
#
# BASE44_TOKEN: access token לסקריפטי Node (seed וכו')
# קבל אותו מהדפדפן כשהאפליקציה פתוחה:
#   DevTools → Console → localStorage.getItem('base44_access_token')
#
BASE44_TOKEN=your_token_here

# YouTube Data API v3 — פרקים עם timestamps אמיתיים מתוך תיאור מלא
# VITE_YOUTUBE_API_KEY=YOUR_KEY
